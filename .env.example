# Required
AZURE_AI_PROJECT_ENDPOINT=https://<your-hub>.openai.azure.com/
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_SUBSCRIPTION_IDS=<your-subscription-id>

# Optional: multiple subscriptions (comma-separated)
# AZURE_SUBSCRIPTION_IDS=sub-id-1,sub-id-2

# Optional: management group scope (overrides per-subscription queries)
# AZURE_MANAGEMENT_GROUP_ID=<your-management-group-id>

# Optional: managed identity for production (omit for az login)
# AZURE_CLIENT_ID=<your-managed-identity-client-id>

# Optional: API key auth instead of credential-based
# AZURE_OPENAI_API_KEY=<your-api-key>

# Optional: observability
# ENABLE_INSTRUMENTATION=true
# ENABLE_SENSITIVE_DATA=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Optional: thresholds (defaults shown)
# COST_AGENT_ANOMALY_THRESHOLD=2.0
# COST_AGENT_BUDGET_RISK_THRESHOLD=0.80
# COST_AGENT_CPU_THRESHOLD=10.0
# COST_AGENT_RI_THRESHOLD=0.70
# COST_AGENT_MAX_RECOMMENDATIONS=50
# COST_AGENT_QUERY_LIMIT=500
# COST_AGENT_METRIC_DAYS=30
# COST_AGENT_MAX_INPUT=4000
